{
  "name": "Annulus",
  "dockerComposeFile": "docker-compose.dev.yml",
  "service": "dev",
  "workspaceFolder": "/workspace",
  "forwardPorts": [8080],
  "portsAttributes": {
    "8080": {
      "label": "Annulus Gateway",
      "onAutoForward": "notify"
    }
  },
  "postCreateCommand": "uv sync --group dev",
  "customizations": {
    "vscode": {
      "extensions": [
        "charliermarsh.ruff",
        "ms-python.python",
        "Continue.continue"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/workspace/.venv/bin/python"
      }
    }
  },
  "remoteEnv": {
    "OLLAMA_HOST": "http://host.docker.internal:11434",
    "ANNULUS_CONFIG_DIR": "/workspace/config",
    "ANNULUS_DATA_DIR": "/workspace/.annulus"
  }
}
