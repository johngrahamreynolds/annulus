{
  "name": "Annulus — External Repo Eval",
  "dockerComposeFile": [
    "../docker-compose.dev.yml",
    "docker-compose.eval.yml"
  ],
  "service": "dev",
  "workspaceFolder": "/workspace",
  "forwardPorts": [8080],
  "portsAttributes": {
    "8080": {
      "label": "Annulus Gateway",
      "onAutoForward": "notify"
    }
  },
  "postCreateCommand": "uv sync --group dev",
  "initializeCommand": "bash .devcontainer/eval/pre-up.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "charliermarsh.ruff",
        "ms-python.python",
        "Continue.continue"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/workspace/.venv/bin/python"
      }
    }
  }
}
