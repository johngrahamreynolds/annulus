# Copy to .env in this directory before opening the eval devcontainer:
#   cp .env.example .env
#
# Absolute path to the external repo you are evaluating (host path).
# macOS/Linux: /Users/you/projects/my-repo
# Windows:     C:\Users\you\projects\my-repo
ANNULUS_EVAL_REPO=/absolute/path/to/external-repo
