# Gateway
ANNULUS_HOST=0.0.0.0
ANNULUS_PORT=8080
ANNULUS_API_KEY=dev-local-key

# Workspace root for indexing and tool sandbox (defaults to cwd)
ANNULUS_WORKSPACE_ROOT=.

# Ollama (host machine — use host.docker.internal inside Docker)
OLLAMA_HOST=http://127.0.0.1:11434

# Config directory
ANNULUS_CONFIG_DIR=config

# Data / index / traces
ANNULUS_DATA_DIR=.annulus
ANNULUS_TRACE_DB=.annulus/traces.db
ANNULUS_INDEX_DB=.annulus/index.db

# Agent
ANNULUS_AGENT_MAX_ITERATIONS=8
ANNULUS_RETRIEVAL_TOP_K=5

# Frontier escalation (optional)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ANNULUS_ESCALATION_ENABLED=true

# External-repo eval: copy .devcontainer/eval/.env.example → .devcontainer/eval/.env
# and set ANNULUS_EVAL_REPO there (see .devcontainer/eval/README.md).
