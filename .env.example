# Annulus local development environment
# Copy to .env and adjust as needed.

# Gateway
ANNULUS_HOST=0.0.0.0
ANNULUS_PORT=8080
ANNULUS_API_KEY=dev-local-key

# Ollama (host machine — use host.docker.internal inside Docker)
OLLAMA_HOST=http://127.0.0.1:11434

# Config directory (defaults to ./config relative to repo root)
ANNULUS_CONFIG_DIR=config

# Trace store
ANNULUS_DATA_DIR=.annulus
ANNULUS_TRACE_DB=.annulus/traces.db

# Optional frontier API (not used in MVP passthrough)
# OPENAI_API_KEY=
# ANNULUS_FRONTIER_BASE_URL=https://api.openai.com/v1
